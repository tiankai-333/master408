/**index.wxss**/

.page {
  min-height: 100vh;
  background: #f5f7fb;
  padding-bottom: 24rpx;
}

.hero {
  margin: 24rpx;
  padding: 34rpx 32rpx;
  border-radius: 12rpx;
  background: #17233d;
  color: #ffffff;
}

.hero-kicker {
  color: #7dd3fc;
  font-size: 24rpx;
  font-weight: 600;
}

.hero-title {
  margin-top: 12rpx;
  font-size: 44rpx;
  font-weight: 700;
}

.hero-desc {
  margin-top: 12rpx;
  color: #dbeafe;
  font-size: 26rpx;
  line-height: 1.5;
}

.hero-row {
  display: flex;
  margin-top: 26rpx;
}

.hero-chip {
  margin-right: 14rpx;
  padding: 8rpx 18rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.12);
  color: #ffffff;
  font-size: 24rpx;
}

.index-collapse {
  font-size: 14px;
  line-height: 24px;
}

.index-collapse-item {
  padding: 8px 15px !important;
  border: 0px !important;
}

.index-cell {
  padding: 5px 15px !important;
}

p{
  display: none;
}
