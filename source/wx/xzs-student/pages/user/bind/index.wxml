<!--pages/user/bind/index.wxml-->
<view class="auth-page">
<view class="brand-card">
  <view class="brand-mark">408</view>
  <view class="brand-name">408Master</view>
  <view class="brand-subtitle">面向计算机考研的刷题、知识点与学习记录助手</view>
</view>

<form bindsubmit='formSubmit'>
  <i-panel title="账号">
    <i-input value="{{ userName }}" name="userName" maxlength="-1"  />
  </i-panel>

  <i-panel title="密码">
    <i-input value="{{ password }}" name="password" maxlength="-1" />
  </i-panel>

  <view>
    <button class="i-btn i-btn- i-btn-primary i-btn-square" form-type='submit'>登录</button>
  </view>
  <view class="auth-tip">
    使用 408Master 学习账号登录，可同步刷题记录、错题和学习动态。没有账号？
    <text bindtap="register" class="auth-link">马上注册</text>
  </view>
  <i-spin size="large" fix wx:if="{{ spinShow }}"></i-spin>
</form>
</view>

<i-message id="message" />
