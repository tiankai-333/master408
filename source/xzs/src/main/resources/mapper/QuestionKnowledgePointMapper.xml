<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mindskip.xzs.repository.QuestionKnowledgePointMapper">

    <resultMap id="BaseResultMap" type="com.mindskip.xzs.domain.QuestionKnowledgePoint">
        <id column="id" property="id"/>
        <result column="question_id" property="questionId"/>
        <result column="knowledge_point_id" property="knowledgePointId"/>
        <result column="relevance" property="relevance"/>
    </resultMap>

    <select id="findByQuestionId" resultMap="BaseResultMap">
        SELECT * FROM question_knowledge_point WHERE question_id = #{questionId}
    </select>

    <select id="findByKnowledgePointId" resultMap="BaseResultMap">
        SELECT * FROM question_knowledge_point WHERE knowledge_point_id = #{knowledgePointId}
    </select>

    <insert id="insert" parameterType="com.mindskip.xzs.domain.QuestionKnowledgePoint">
        INSERT INTO question_knowledge_point (question_id, knowledge_point_id, relevance)
        VALUES (#{questionId}, #{knowledgePointId}, #{relevance})
    </insert>

    <delete id="deleteByQuestionId">
        DELETE FROM question_knowledge_point WHERE question_id = #{questionId}
    </delete>

    <delete id="deleteByKnowledgePointId">
        DELETE FROM question_knowledge_point WHERE knowledge_point_id = #{knowledgePointId}
    </delete>

</mapper>